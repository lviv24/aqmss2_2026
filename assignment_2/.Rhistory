#adding a new binary variable for success of assassination attempts
leaders<-leaders%>%
mutate(success = case_when(
result %in% c(
"dies within a day after the attack",
"dies between a day and a week",
"dies, timing unknown",
"dies between a week and a month"
) ~ 1,
TRUE ~0
))
#%in% use when have multiple values to account for
#adding new binary variable to existing dataset
leaders<-leaders%>% #overriding old dataset with new mutated dataset
mutate(warbefore = case_when(
interwarbefore|civilwarbefore %in% c(
1
) ~ 1,
TRUE ~ 0
))
#LINE 68 notes
#mutate is when you are altering data you already have by adding a new variable.
#telling r i want there to be a 1 when the interwarbefore column has a 1
#c is this symbol for OR bc we are working on two columns
# tilde is saying when 1 interware before or civilwar before =1 the new column is a 1
