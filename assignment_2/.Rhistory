library(dplyr)
library(ggplot2)
library(broom)
years <- unique(blackturnout$year)
for (year in years) {
model <- lm(turnout ~ candidate, data = subset(blackturnout, year == year))
coef_candidate <- summary(model)$coefficients["candidate", "Estimate"]
if (coef_candidate > 0) {
print(year)
}
