education = case_when(
V201511x == 1 ~ 10, V201511x == 2 ~ 12, V201511x == 3 ~ 14,
V201511x == 4 ~ 16, V201511x == 5 ~ 20, TRUE ~ NA_real_),
income = ifelse(V201617x < 0, NA, V201617x),
