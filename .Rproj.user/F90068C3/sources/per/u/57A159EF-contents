library(tidyverse)

qog <- read.csv("qog_std_cs_jan26.csv")

qog_clean <- qog %>%
  select(
    country = cname,
    epi = epi_epi,
    women_parl = wdi_wip,
    gov_eff = wbgi_gee,
    green_seats = cpds_lg
  ) %>%
  drop_na()

nrow(qog_clean)

summary(qog_clean)

ggplot(qog_clean, aes(x = women_parl, y = epi)) +
  geom_point() +
  geom_smooth(method = "lm", se = TRUE) +
  labs(
    x = "Women in Parliament (%)",
    y = "Environmental Performance Index",
    title = "Women in Parliament vs EPI"
  ) +
  theme_minimal()
